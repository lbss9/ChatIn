NODE_ENV=development
PORT=3003

# MongoDB local iniciado pelo docker-compose.yml
MONGODB_PORT=27018
MONGODB_USERNAME=chatin
MONGODB_PASSWORD=change-this-local-password
MONGODB_DATABASE=chatin
MONGODB_URI=mongodb://chatin:change-this-local-password@localhost:27018/chatin?authSource=admin

WEB_ORIGIN=http://localhost:3000,http://localhost:3001
WEBSOCKET_ORIGIN=http://localhost:3000,http://localhost:3001
APP_URL=http://localhost:3001

JWT_ACCESS_SECRET=generate-a-long-random-secret
JWT_REFRESH_SECRET=generate-a-different-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Opcional em desenvolvimento; sem SMTP, o link de recuperação aparece no log.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ChatIn <noreply@chatin.local>
SWAGGER_ENABLED=true
