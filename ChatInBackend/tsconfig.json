{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2023",
        "sourceMap": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "incremental": true,
        "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
        "strict": true,
        "strictPropertyInitialization": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts"
    ]
}
